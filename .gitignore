# =============================================================================
# NGKsSystems - hardened ignore rules (build/proof/artifacts/secrets)
# =============================================================================

# ---- OS junk ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Node / Electron ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
dist-*/
dist-electron/
dist-native/
release/
.releases/
.cache/
.eslintcache

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.env
.env.*
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Build (general) ----
artifacts/
_artifacts/
artifacts_proof/
out/
build/
Debug/
Release/
x64/
x86/
Win32/

# ---- C/C++ intermediates ----
*.obj
*.pdb
*.ilk
*.pch
*.idb
*.tlog
*.exp
*.lib
*.dll
*.exe
*.manifest
*.res
*.aps
*.log

# ---- Ninja ----
.ninja_*

# ---- MSVC / IDEs ----
.vs/
.idea/
.vscode/
*.user
*.suo
*.vcxproj.user

# ---- Runtime logs / proof bundles ----
_proof/
_proof/**
*_proof/
*_proof/**
proof/
proof/**
logs/
logs/**
log/
log/**
*.dmp
*.zip
*.7z
*.rar

# ---- Crash / profiling ----
*.core
*.stackdump
*.profraw
*.profdata

# ---- Secrets / credentials (block common files) ----
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.jks
*.keystore
*.kdbx
*.ovpn
*id_rsa*
*id_ed25519*
credentials*.json
service-account*.json
secrets*.json
secrets*.txt
tokens*.txt
token*.txt

# ---- Local config (force users to keep private copies) ----
.local/
.local/**
_local/
_local/**
private/
private/**