#include <chrono>
#include <cstdint>
#include <functional>
#include <iostream>
#include <random>
#include <string>
#include <thread>
#include <vector>

#include "ngk/event_loop.hpp"

static void line(const std::string& s) { std::cout << s << "\n"; }

int main() {
  using namespace std::chrono;

  bool ok = true;
  auto fail = [&](const std::string& msg) { ok = false; line("FAIL: " + msg); };
  auto pass = [&](const std::string& msg) { line("PASS: " + msg); };

  // Detect API names without hard-coding (compile-time via header contract):
  // Your EventLoop contract already exists; keep calls minimal.

  // ---- Test 1: stop() from within timeout callback ----
  {
    ngk::EventLoop loop;
    bool fired = false;

    // pump hook path (no platform)
    loop.set_platform_pump([]{});

    loop.set_timeout(milliseconds(10), [&] {
      fired = true;
      loop.stop();
    });

    loop.run();

    if (!fired) fail("stop-from-timeout did not fire");
    else pass("stop-from-timeout executes");
  }

  // ---- Test 2: interval cancel mid-flight (elapsed-based, not tick fantasy) ----
  // Expect: reaches cancel point eventually and stops producing ticks after cancel (allow small slack).
  {
    ngk::EventLoop loop;
    loop.set_platform_pump([]{});

    std::uint64_t ticks = 0;
    std::uint64_t id = 0;

    id = loop.set_interval(milliseconds(10), [&] {
      ticks++;
      if (ticks == 8) {
        loop.cancel_timer(id);
      }
    });

    loop.set_timeout(milliseconds(300), [&] { loop.stop(); });
    loop.run();

    // After 300ms with 10ms period, we'd expect ~30 ticks if uncancelled.
    // Cancel at 8: allow a couple extra due to scheduling.
    if (ticks < 8) fail("interval did not reach cancel point (ticks=" + std::to_string(ticks) + ")");
    else if (ticks > 12) fail("interval ran too long after cancel (ticks=" + std::to_string(ticks) + ")");
    else pass("interval cancels cleanly (ticks=" + std::to_string(ticks) + ")");
  }

  // ---- Test 3: cancel unknown id must be safe ----
  {
    ngk::EventLoop loop;
    loop.set_platform_pump([]{});

    // Must not crash/hang.
    loop.cancel_timer(999999999ULL);
    pass("cancel unknown id safe");
  }

  // ---- Test 4: timer storm (10k timeouts 0..200ms) ----
  {
    ngk::EventLoop loop;
    loop.set_platform_pump([]{});

    std::mt19937 rng(1337);
    std::uniform_int_distribution<int> dist(0, 200);

    const int N = 10000;
    std::uint64_t fired = 0;

    for (int i = 0; i < N; i++) {
      loop.set_timeout(milliseconds(dist(rng)), [&] { fired++; });
    }

    loop.set_timeout(milliseconds(260), [&] { loop.stop(); });
    loop.run();

    if (fired < static_cast<std::uint64_t>(N * 95 / 100))
      fail("timer storm fired too few callbacks: " + std::to_string(fired));
    else
      pass("timer storm fired callbacks: " + std::to_string(fired));
  }

  // ---- Test 5: post() storm (100k posts) ----
  {
    ngk::EventLoop loop;
    loop.set_platform_pump([]{});

    const int N = 100000;
    std::uint64_t ran = 0;

    for (int i = 0; i < N; i++) {
      loop.post([&] { ran++; });
    }

    loop.set_timeout(milliseconds(150), [&] { loop.stop(); });
    loop.run();

    // Should be very high; allow slack if throttled.
    if (ran < static_cast<std::uint64_t>(N * 90 / 100))
      fail("post storm ran too few callbacks: " + std::to_string(ran));
    else
      pass("post storm ran callbacks: " + std::to_string(ran));
  }

  // ---- Test 6: cross-thread stop() ----
  {
    ngk::EventLoop loop;
    loop.set_platform_pump([]{});

    std::thread t([&] {
      std::this_thread::sleep_for(milliseconds(50));
      loop.stop();
    });

    loop.run();
    t.join();
    pass("cross-thread stop exits run()");
  }

  line(ok ? "SUMMARY: PASS" : "SUMMARY: FAIL");
  return ok ? 0 : 1;
}
